# Copy to config.env and fill in for LOCAL runs:  set -a; . ./config.env; set +a
# For GitHub Actions, set these as repo Secrets/Variables instead (see README).

# What to watch --------------------------------------------------------------
SOURCES=stubhub,viagogo,vividseats  # stubhub+viagogo are HTTP-only; vividseats needs a browser
QUANTITY=6                          # tickets that must be seated together
# Event URLs default to Match 95 (Round of 16, W86 vs W88, Atlanta, Jul 7 2026):
# STUBHUB_URL=https://www.stubhub.com/world-cup-atlanta-tickets-7-7-2026/event/155049347/
# VIAGOGO_URL=https://www.viagogo.com/Sports-Tickets/Soccer/Soccer-Tournament/World-Cup-Tickets/E-155049347
# VIVID_URL=https://www.vividseats.com/world-cup-soccer-tickets-mercedes-benz-stadium-7-7-2026--sports-soccer/production/5080860

# Alert mode -----------------------------------------------------------------
# Emails a digest of every viable listing (sorted cheapest-first) whenever a NEW
# listing appears or an existing one's price moves. The email has three sections:
# NEW FINDS, PRICE CHANGES, and STILL AVAILABLE (unchanged repeats).
# Leave MAX_PRICE blank -> every seated-together listing is "viable".
# Set MAX_PRICE -> only listings at/below this per-ticket price count as viable.
# (Market is ~$2,270/ticket all-in as of Jun 30.)
MAX_PRICE=

# Ignore price wobbles smaller than this ($/ticket) so trivial fluctuations don't
# trigger a "price change" email every run. Default 25.
PRICE_CHANGE_MIN=25

# Email (Gmail) --------------------------------------------------------------
# SMTP_USER is the SENDING account. SMTP_PASS must be that account's Google
# *App Password* (16 chars), NOT its normal password.
# Create at https://myaccount.google.com/apppasswords (needs 2-Step Verification on).
SMTP_USER=agentcodymann@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
EMAIL_TO=armandomann@gmail.com
