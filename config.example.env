# Copy to config.env and fill in for LOCAL runs:  set -a; . ./config.env; set +a
# For GitHub Actions, set these as repo Secrets/Variables instead (see README).

# What to watch --------------------------------------------------------------
SOURCES=stubhub,vividseats          # or just "stubhub" (no browser needed)
QUANTITY=6                          # tickets that must be seated together
# Event URLs default to Match 95 (Round of 16, W86 vs W88, Atlanta, Jul 7 2026):
# STUBHUB_URL=https://www.stubhub.com/world-cup-atlanta-tickets-7-7-2026/event/155049347/
# VIVID_URL=https://www.vividseats.com/world-cup-soccer-tickets-mercedes-benz-stadium-7-7-2026--sports-soccer/production/5080860

# Alert mode -----------------------------------------------------------------
# Leave MAX_PRICE blank -> emails on first appearance + every price drop.
# Set MAX_PRICE -> "deal mode": stays quiet and ONLY emails when 6-together is at
# or below this per-ticket price. (Market is ~$2,270/ticket all-in as of Jun 30.)
MAX_PRICE=

# Email (Gmail) --------------------------------------------------------------
# SMTP_PASS must be a Google *App Password* (16 chars), NOT your normal password.
# Create at https://myaccount.google.com/apppasswords (needs 2-Step Verification on).
SMTP_USER=armandomann@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
EMAIL_TO=armandomann@gmail.com
