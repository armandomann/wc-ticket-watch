# Copy to config.env and fill in for LOCAL runs:  set -a; . ./config.env; set +a
# For GitHub Actions, set these as repo Secrets/Variables instead (see README).

# What to watch --------------------------------------------------------------
SOURCES=stubhub,viagogo,vividseats  # stubhub+viagogo are HTTP-only; vividseats needs a browser
QUANTITY=5                          # how many tickets you need

# Grouping mode:
#   section  — QUANTITY seats within ONE section, possibly across several listings
#              (rows needn't be adjacent). Each listing must still be <= MAX_PRICE.
#   together — a single listing selling QUANTITY seats seated together (original).
GROUP=section

# StubHub/viagogo embed only a partial, rotating subset of listings per request,
# so the watcher fetches the page a few times and unions the results to cover the
# inventory. More passes = better coverage but slower/more requests.
SH_PASSES=8                         # fetches per StubHub/viagogo source
SH_PASS_DELAY=1.5                   # seconds between those fetches
# Event URLs default to the Final (Match 104, MetLife Stadium, Sun Jul 19 2026):
# STUBHUB_URL=https://www.stubhub.com/world-cup-east-rutherford-tickets-7-19-2026/event/153020449/
# VIAGOGO_URL=https://www.viagogo.com/Sports-Tickets/Soccer/Soccer-Tournament/World-Cup-Tickets/E-153020449
# VIVID_URL=https://www.vividseats.com/world-cup-soccer-tickets-hard-rock-stadium-7-19-2026--sports-soccer/production/5080877
EVENT_TAG=WC Final
EVENT_LABEL=World Cup Final (Match 104, MetLife Stadium, Jul 19)

# Alert mode -----------------------------------------------------------------
# Emails a digest of every viable offer (cheapest-first) whenever a NEW offer
# appears or an existing one's price moves: NEW FINDS, PRICE CHANGES, STILL
# AVAILABLE. In section mode an "offer" is a whole-section package of QUANTITY.
# MAX_PRICE is a per-ticket ceiling (each listing in a package must be <= it).
# Leave blank -> no ceiling. The Final's floor was ~$7,900/tk as of Jul 16.
MAX_PRICE=8000

# Ignore price wobbles smaller than this ($/ticket) so trivial fluctuations don't
# trigger a "price change" email every run. Default 25.
PRICE_CHANGE_MIN=25

# Email (Gmail) --------------------------------------------------------------
# SMTP_USER is the SENDING account. SMTP_PASS must be that account's Google
# *App Password* (16 chars), NOT its normal password.
# Create at https://myaccount.google.com/apppasswords (needs 2-Step Verification on).
SMTP_USER=agentcodymann@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
EMAIL_TO=armandomann@gmail.com
