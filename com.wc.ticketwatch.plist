<?xml version="1.0" encoding="UTF-8"?>
<!-- Local scheduler: runs the watcher every 30 minutes while your Mac is awake.
     EDIT the ProgramArguments path below to this folder's absolute path. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wc.ticketwatch</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/cody/Claude/wc-ticket-watch/run-local.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>1800</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/cody/Claude/wc-ticket-watch/watch.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/cody/Claude/wc-ticket-watch/watch.log</string>
</dict>
</plist>
